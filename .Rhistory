names(source_upset_labelled)[
match(source_order, names(source_upset_labelled))
] <- source_label_map
source_sets_labelled <- unname(source_label_map[rev(source_order)])
fig_source_upset <- ComplexUpset::upset(
source_upset_labelled,
intersect = source_sets_labelled,
base_annotations = list(
"Intersection size" = ComplexUpset::intersection_size(
counts = TRUE,
text = list(size = 5),
mapping = aes(fill = "intersection")
) +
scale_fill_manual(
values = c(intersection = "#8B864E"),
guide = "none"
)),
set_sizes = FALSE,
sort_intersections_by = "cardinality",
sort_sets = FALSE,
min_size = 1,
matrix = intersection_matrix(
geom = geom_point(
shape = 21,
size = 4.2,
stroke = 0.8,
fill = "#CD8162"
),
segment = ggplot2::geom_segment(linewidth = 0.9, colour = "#CD8162"),
outline_color = list(active = "#333333", inactive = "#ededed"
))) +
labs(x = NULL, y = "Intersection size") +
theme(
text = element_text(size = 16),
axis.text.x = element_blank(),
axis.ticks.x = element_blank(),
axis.title.x = element_blank()
)
