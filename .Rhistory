bib_data <- convert2df(file.path(data_dir, "scopusData.bib"), dbsource = "scopus", format = "bibtex")
bib_data <- metaTagExtraction(bib_data, Field = "AU_CO", sep = ";")
net_matrix <- biblioNetwork(
bib_data,
analysis = "collaboration",
network  = "countries",
sep  = ";"
) |>
as.matrix()
net_matrix[lower.tri(net_matrix)] <- 0
rownames(net_matrix) <- str_to_title(rownames(net_matrix))
colnames(net_matrix) <- str_to_title(colnames(net_matrix))
rownames(net_matrix)[rownames(net_matrix) == "Usa"] <- "USA"
colnames(net_matrix)[colnames(net_matrix) == "Usa"] <- "USA"
rownames(net_matrix)[rownames(net_matrix) == "United Kingdom"] <- "UK"
colnames(net_matrix)[colnames(net_matrix) == "United Kingdom"] <- "UK"
country_strength <- rowSums(net_matrix) + colSums(net_matrix)
### top 18 countries ----
keep_countries_18 <- names(
sort(country_strength[country_strength > 0], decreasing = TRUE)
)[1:min(18, sum(country_strength > 0))]
net_matrix_18 <- net_matrix[keep_countries_18, keep_countries_18, drop = FALSE]
net_matrix_18 <- net_matrix_18[
rowSums(net_matrix_18) + colSums(net_matrix_18) > 0,
colSums(net_matrix_18) + rowSums(net_matrix_18) > 0,
drop = FALSE
]
chord_cols_18 <- setNames(
c("#3B6EA8", "#4B9A8D", "#D6A24A", "#B76D68", "#6D7783", "#8A6FA8",
"#7FA35B", "#5E8C9A", "#C58A5A", "#8C7853", "#5B8E7D", "#A05C7B",
"#7895B2", "#B8A052", "#6F7D55", "#9B7E7E", "#4F7B8A", "#8E9A6B"
)[seq_along(rownames(net_matrix_18))],
rownames(net_matrix_18)
)
draw_chord_top18 <- function() {
par(mar = c(0.5, 0.5, 0.5, 0.5))
circos.clear()
circos.par(
track.margin = c(0.01, 0.01),
gap.degree   = 2,
canvas.xlim  = c(-1.25, 1.25),
canvas.ylim  = c(-1.25, 1.25)
)
chordDiagram(
net_matrix_18,
annotationTrack = "grid",
annotationTrackHeight = c(0.04, 0.02),
preAllocateTracks  = 1,
grid.col = chord_cols_18,
transparency = 0.35
)
circos.trackPlotRegion(
track.index = 1,
panel.fun = function(x, y) {
xlim <- get.cell.meta.data("xlim")
ylim <- get.cell.meta.data("ylim")
sector.name <- get.cell.meta.data("sector.index")
circos.text(
mean(xlim), ylim[1] + 0.25,
sector.name,
facing = "clockwise",
niceFacing = TRUE,
adj = c(0, 0.5),
cex = 0.7,
col = "#333333"
)
},
bg.border = NA
)
circos.clear()
}
chord_pdf_18 <- file.path(pdf_dir, "figure7_chord_top18.pdf")
chord_png_18 <- file.path(png_dir, "figure7_chord_top18.png")
pdf(chord_pdf_18, width = 7, height = 7, useDingbats = FALSE)
draw_chord_top18()
dev.off()
png(chord_png_18, width = 5400, height = 5400, res = 450, bg = "white")
draw_chord_top18()
dev.off()
### all countries ----
keep_all <- names(country_strength[country_strength > 0])
net_matrix_all <- net_matrix[keep_all, keep_all, drop = FALSE]
net_matrix_all <- net_matrix_all[
rowSums(net_matrix_all) + colSums(net_matrix_all) > 0,
colSums(net_matrix_all) + rowSums(net_matrix_all) > 0,
drop = FALSE
]
ord_all <- names(sort(rowSums(net_matrix_all) + colSums(net_matrix_all), decreasing = TRUE))
net_matrix_all <- net_matrix_all[ord_all, ord_all, drop = FALSE]
base_cols <- c(
"#3B6EA8", "#4B9A8D", "#D6A24A", "#B76D68", "#6D7783", "#8A6FA8",
"#7FA35B", "#5E8C9A", "#C58A5A", "#8C7853", "#5B8E7D", "#A05C7B",
"#7895B2", "#B0C052", "#6F7D55", "#9B7E7E", "#4F7B8A", "#8E9A6B",
"#9e907e", "#dea5a4", "#898441", "#af9392", "#8d9490", "#708090",
"#cd7f32", "#32cd4b", "#7f32cd", "#ca4a46", "#63000f", "#de3163",
"#434d57", "#707390", "#908070", "#e3735e", "#e35e7e", "#364758",
"#b22222", "#8eb222", "#22b2b2", "#ffd700", "#682860", "#685028",
"#013220", "#038756"
)
country_names_all <- rownames(net_matrix_all)
country_names_lookup <- country_names_all
country_names_lookup[country_names_lookup == "UK"] <- "United Kingdom"
country_codes_all <- countrycode(
sourcevar = country_names_lookup,
origin = "country.name",
destination = "iso3c",
warn = TRUE
)
country_codes_all[country_names_all == "USA"] <- "USA"
country_codes_all[country_names_all == "UK"] <- "GBR"
country_codes_all[is.na(country_codes_all)] <- country_names_all[is.na(country_codes_all)]
rownames(net_matrix_all) <- country_codes_all
colnames(net_matrix_all) <- country_codes_all
cols_all <- setNames(
colorRampPalette(base_cols[seq_len(nrow(net_matrix_all))])(nrow(net_matrix_all)),
rownames(net_matrix_all)
)
chord_png_all <- file.path(out_dir, "chord_all_countries.png")
png(chord_png_all, width = 5000, height = 5000, res = 500, bg = "white")
par(mar = c(0.5, 0.5, 0.5, 0.5))
circos.clear()
circos.par(
track.margin = c(0.005, 0.005),
gap.degree   = 1,
canvas.xlim  = c(-1.30, 1.30),
canvas.ylim  = c(-1.30, 1.30)
)
chordDiagram(
net_matrix_all,
annotationTrack = "grid",
annotationTrackHeight = c(0.035, 0.015),
preAllocateTracks = 1,
grid.col = cols_all,
transparency = 0.45
)
circos.trackPlotRegion(
track.index = 1,
panel.fun = function(x, y) {
xlim <- get.cell.meta.data("xlim")
ylim <- get.cell.meta.data("ylim")
sector.name <- get.cell.meta.data("sector.index")
circos.text(
mean(xlim), ylim[1] + mm_y(3.0),
sector.name,
facing = "clockwise",
niceFacing = TRUE,
adj = c(0, 0.5),
cex = 0.45,
